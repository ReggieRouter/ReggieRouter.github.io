    (function($){
    
        $(document).ready(function() {
  // Get the button element by ID
  $(document).on('click','#gform_next_button_5_10, #gform_next_button_24_10, #gform_next_button_12_10, #gform_next_button_15_10, #gform_next_button_18_10, #gform_next_button_22_10', function() {
    // Get the button value
    var buttonValue = $(this).val();
    let currentUrl = window.location.href;
    if(currentUrl.includes('#get-started')){
        let tempurl = currentUrl.split('#');
        currentUrl = tempurl[0];
    }
    let newUrl;
        if (currentUrl.endsWith('/')) {
            if(currentUrl.includes('step1completed')){
                newUrl = currentUrl;
            }else{
                newUrl = currentUrl + 'step1completed/';
            }
        } else if (!currentUrl.endsWith('/step1completed/')) {
            if( currentUrl.includes('utm_medium')){
                let tempurl = currentUrl.split('?');
                if( currentUrl.includes('step1completed')){
                    newUrl = currentUrl;
                }else{
                    newUrl = tempurl[0] + 'step1completed/?' + tempurl[1];
                }
            }else{
                newUrl = currentUrl + 'step1completed/';
            }
        } else {
            console.log('The URL already ends with');
            return; // Do nothing if the URL already ends with '/1/'
        }

        history.pushState(null, '', newUrl);
        console.log('URL updated to: ' + newUrl);
    
    // Push to Google Analytics
    if (typeof gtag === 'function') {
      gtag('event', 'step1completion', {
        'event_category': 'Form',
        'event_label': 'Step 1 Complete',
        'value': buttonValue
      });
    } else if (typeof ga === 'function') {
      ga('send', {
        'hitType': 'event',
        'eventCategory': 'Form',
        'eventAction': 'step1completion',
        'eventLabel': 'Step 1 Complete',
        'eventValue': buttonValue
      });
    } else if (typeof dataLayer !== 'undefined') {
      dataLayer.push({
        'event': 'step1completion',
        'formStep': 'Step 1 Complete',
        'buttonValue': buttonValue
      });
    }
    // Log to console
    console.log('Form step 1 submitted with value: ' + buttonValue);
  });
});
})(jQuery);
