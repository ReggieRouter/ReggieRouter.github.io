<style id="wp-custom-css">
body img.gform_ajax_spinner,
body.post-type-archive-fundkiteteam .page-header .entry-title {
	display: none !important;
}
body .gform_wrapper .gform_ajax_spinner {
	margin-top: -5px;
	margin-left: -40px;
	position: absolute;
	display: none!important;
}

.elementor-sticky--effects,
.elementor-sticky--active {
    background: #ffffff;
}
.pricelist {
	overflow: hidden;
	border-radius: 30px;
}

.pricelist .elementor-price-table__features-list li:nth-child(odd) {
	background: #C3C3C3;
}

.pricelist .elementor-price-table__features-list li {
	background: #ADADAD;
	padding: 20px 0 !important;
}

.pricelist .elementor-price-table__features-list li:before {
	display: none !important;
}

.pricelist-active .elementor-price-table__features-list li:nth-child(odd) {
	background: #D7DEED;
}

.pricelist-active .elementor-price-table__features-list li {
	background: #8A9FCD;
}

.pricelist.pricelist-active .elementor-price-table__features-list li:last-child {
	padding-bottom: 20px !important;
}

.pricelist .elementor-price-table__features-list li:last-child {
	padding-bottom: 45px !important;
}

/* Start Blog */
div .elementor-posts .elementor-post__card {
	display: block;
}
div .elementor-posts--thumbnail-top .elementor-post__thumbnail__link {
	margin-bottom: 10px;
}
div .elementor-posts .elementor-post__card .elementor-post__text {
	padding: 0;
}
div .elementor-posts .elementor-post__card .elementor-post__meta-data {
	padding: 0;
	border: 0;
}

.elementor-pagination .page-numbers {
	width: 32px;
	height: 32px;
	border: 1px solid #707070;
	display: inline-block;
    text-align: center;
    line-height: 29px;
}
.elementor-pagination .page-numbers:hover,
.elementor-pagination .page-numbers.current {
	border-color: #3d5fac;
}
.elementor-kit-5 h1,
.elementor-kit-5 h2,
.elementor-kit-5 h3,
.elementor-kit-5 h4,
.elementor-kit-5 h5,
.elementor-kit-5 h6 {
	color: #000;
	font-weight: 700;
}
.elementor-kit-5 h3 {
	font-size: 20px;
}
.elementor-kit-5 h4 {
	font-size: 16px;
}
.elementor-widget-wp-widget-recent-posts h5 {
/* 	font-family: Playfair Display; */
	font-size: 20px;
	font-weight: 700;
}
.elementor-widget-wp-widget-recent-posts ul {
	list-style: none;
	padding: 0;
    margin-bottom: 5px !important;
}
.elementor-widget-wp-widget-recent-posts ul li {
    border-bottom: 1px solid #d6d6d6;
    padding-bottom: 10px;
    margin-bottom: 10px;
}
.elementor-widget-wp-widget-recent-posts ul li:last-child{
	 border-bottom:0;
    padding-bottom: 0px;
    margin-bottom: 0px;
}
.elementor-widget-wp-widget-recent-posts {
    padding: 15px!Important;
    box-shadow: 0 6px 20px 0 rgb(20 45 117 / 0.08);
    background-color: white;
    border-radius: 12px;
}
.elementor-widget-wp-widget-recent-posts ul li a {
    font-size: 14px;
    color: #112346;
    font-weight: 600;
}
.elementor-widget-wp-widget-recent-posts ul li a:hover {
	color: #3d5fac;
}
.wp-block-quote {
	padding: 10px 20px;
	margin: 0 0 20px;
	border-left: 5px solid #eee;
}
.wp-block-quote p {
	margin: 0;
}
.wp-block-quote p + p {
	margin-top: 15px;
}
.single-post ul li + li,
.single-post ol li + li {
	margin-top: 10px;
}
.single-post ul,
.single-post ol {
	margin-bottom: 20px;
}
/* End Blog */

/* Start Mega Menu */
.mega-sub-menu {
	box-shadow: 0 3px 15px rgba(0, 0, 0, .05) !important;
}
@media (min-width: 769px) {
	.mega-menu-item-has-children>a:before {
	content: "";
   border-bottom: 16px solid #43a1d5;
   border-right: 16px solid transparent;
   border-left: 16px solid transparent;
   position: absolute !important;
   left: calc(50% - 16px) !important;
/*    top: 24px !important; */
		top: 30px !important;
	opacity: 0;
	visibility: hidden;
/* 	transition: opacity 200ms ease-in, visibility 200ms ease-in; */
	z-index: 9999;
}
.mega-menu-item-has-children>a:after {
	content: "";
   border-bottom: 16px solid #fff;
   border-right: 16px solid transparent;
   border-left: 16px solid transparent;
   position: absolute !important;
   left: calc(50% - 16px) !important;
/*    top: 28px !important; */
	top: 34px !important;
	display: block !important;
	opacity: 0;
	visibility: hidden;
/* 	transition: opacity 200ms ease-in, visibility 200ms ease-in; */
	z-index: 9999;
}
/* .mega-menu-item-has-children:hover>a:before {
	opacity: 1;
	visibility: visible;
}
.mega-menu-item-has-children:hover>a:after {
	opacity: 1;
	visibility: visible;
} */
	
a.mega-menu-link[aria-expanded="true"]:before, a.mega-menu-link[aria-expanded="true"]:after {
    opacity: 1 !important;
    visibility: visible !important;
}
	#mega-menu-wrap-menu-1 #mega-menu-menu-1[data-effect="fade_up"] li.mega-menu-item.mega-menu-megamenu > ul.mega-sub-menu, #mega-menu-wrap-menu-1 #mega-menu-menu-1[data-effect="fade_up"] li.mega-menu-item.mega-menu-flyout ul.mega-sub-menu {
		transform: translate(0, 4px) !important ;
		transition: none !important;
	}
}
/* End Mega Menu */
/* Start Mobile Menu */
@media (max-width: 1024px) {
	.elementor-nav-menu--dropdown {
		top: 70px !important;
	}
}
@media (max-width: 768px) {
	div .elementor-menu-toggle {
		padding: 0;
	}
	.elementor-nav-menu--dropdown .elementor-nav-menu .sub-arrow .e-font-icon-svg.fa-svg-chevron-down {
		fill: #fff;
	}
	.elementor-nav-menu--dropdown {
		top: 45px !important;
	}
}
/* End Mobile Menu */
/* Start Contact Page */
@media (min-width: 1025px) {
	#gform_1 .gform_footer {
	align-items: center;
	flex-wrap: nowrap;
