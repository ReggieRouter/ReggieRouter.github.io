id element_classes alignnone no_border mfn-img-box" ><div class="image_wrapper"><img width="280" height="88" src="https://spartancapital.com/wp-content/uploads/2025/10/perfect-white.png" class="scale-with-grid" alt="" style="" decoding="async" loading="lazy" srcset="https://spartancapital.com/wp-content/uploads/2025/10/perfect-white.png 280w, https://spartancapital.com/wp-content/uploads/2025/10/perfect-white-150x47.png 150w" sizes="auto, (max-width:767px) 280px, 280px" /></div></div>
