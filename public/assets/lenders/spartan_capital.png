<style id="mfn-custom-inline-css">
/ *CONTACT FORM 7* /

.wpcf7-submit {
    width: 90% !important;
}


/ *DROPDOWN MENU* /

.sub-menu li{
   font-size:6px;
}

.menuo-arrows #Top_bar .menu > li.submenu > a > span:not(.description)::after {
    border-top-color: #182b55;
}

#Action_bar *{
   font-size: 15px;
}
.menu .sub-menu span{
   font-size: 14px;
}

#Footer .footer_action {
    background: rgb(0 0 0 / 0%);
}

body.keyboard-support .image_frame .image_wrapper:not(.hover-secondary-image){
   overflow: hidden!important;
}

/* Single Post: Video */
.single-photo-wrapper.video video{width:100%}
/*# sourceURL=mfn-custom-inline-css */
</style>
