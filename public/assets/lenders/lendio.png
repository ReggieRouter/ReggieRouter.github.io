<script>
function setLaunchFile(env){
    let script = document.createElement("script")
    script.async = true
    script.id = "adobe-launch"
    script.src = env
    script.defer = true
    document.head.appendChild(script) 
}

function envCheck(){
    //console.log("envCheck() called");
    if(window.cookieManager || window.dreams) {
        //console.log("Cookie manager or dreams found");
        this.cookieManager = window.cookieManager ?? window.dreams.cookieManager;
        let queryString = window.location.search;
        let urlParams = new URLSearchParams(queryString);
        let adobeTestParam = urlParams.get('adobeTest');
        //console.log("adobeTestParam: ", adobeTestParam);
        let adobeTestCookie;

        if (!this.cookieManager) {
            //console.log("No cookie manager");
        } else if(adobeTestParam){
            this.cookieManager.set('adobeTest', true, '');
            adobeTestCookie = this.cookieManager.get('adobeTest');
            //console.log("adobeTestCookie after param set: ", adobeTestCookie);
        } else if(this.cookieManager.get('adobeTest')) {
            adobeTestCookie = this.cookieManager.get('adobeTest');
            //console.log("adobeTestCookie from existing: ", adobeTestCookie);
        }

        if (adobeTestCookie == 'true' || adobeTestParam == 'true') {
            //console.log("Loading development launch file");
            setLaunchFile('//assets.adobedtm.com/1dc6abc16afc/980b51eb0fa8/launch-6c4ec0b73ade-development.min.js');
        }
        else{
            //console.log("Loading production launch file");
            setLaunchFile('//assets.adobedtm.com/1dc6abc16afc/980b51eb0fa8/launch-1c1a32bf4d72.min.js');
        }
    } else {
        //console.log("Cookie manager or dreams not found");
        setLaunchFile('//assets.adobedtm.com/1dc6abc16afc/980b51eb0fa8/launch-1c1a32bf4d72.min.js');
       
    }
}
envCheck();
</script>
