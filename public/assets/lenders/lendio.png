<!-- Navbar variations for embedded and intelligent lending pages Start -->
<script>
document.addEventListener("DOMContentLoaded", function() {
    const currentUrl = window.location.href;
    const signinButton = document.getElementById('signin-button');
    const supportButton = document.getElementById('support-button');

    // Mappings for keywords
    const ctaConfig = {
        "embedded-financing": { text: "Talk to our team", link: "#ready-to-learn", signIn: "https://portal.lendio.com/auth/login" },
        "intelligent-lending": { text: "Talk to our team", link: "#ready-to-learn", signIn: "https://portal.lendio.com/auth/login" },
        "ef-features": { text: "Talk to our team", link: "#ready-to-learn", signIn: "https://portal.lendio.com/auth/login" },
        "il-features": { text: "Talk to our team", link: "#ready-to-learn", signIn: "https://portal.lendio.com/auth/login" },
    };
  
  if (currentUrl.includes("/intelligent-lending/resources/")) {
        return;
    }

    // Update navbar
    function updateNavbar(config) {
        document.querySelectorAll("[data-cta]").forEach(ctaElement => {
            ctaElement.textContent = config.text;
            ctaElement.href = config.link;
            signinButton.href = config.signIn;
        });
            supportButton.style.display = "none";
    }

    // Check for keywords in the URL and call the function
    Object.keys(ctaConfig).forEach(keyword => {
        if (currentUrl.includes(keyword)) {
            updateNavbar(ctaConfig[keyword]);
        }
    });
});
  const replaceDatePlaceholders = () => {
  // 1. Get current date in Mountain Time (MST/MDT)
  const now = new Date();
  const mtMonth = now.toLocaleString("en-US", { month: "long", timeZone: "America/Denver" });
  const mtYear = now.toLocaleString("en-US", { year: "numeric", timeZone: "America/Denver" });

  // 2. Update the Browser Tab Title (<title> tag)
  if (document.title.includes("{{month}}") || document.title.includes("{{year}}")) {
    document.title = document.title
      .replace(/{{month}}/g, mtMonth)
      .replace(/{{year}}/g, mtYear);
  }

  // 3. Update the Body Content
  if (document.body) {
    const walker = document.createTreeWalker(
      document.body,
      NodeFilter.SHOW_TEXT,
      null,
      false
    );

    let node;
    while ((node = walker.nextNode())) {
      let text = node.textContent;
      let modified = false;

      if (text.includes("{{month}}")) {
        text = text.replace(/{{month}}/g, mtMonth);
        modified = true;
      }
      if (text.includes("{{year}}")) {
        text = text.replace(/{{year}}/g, mtYear);
        modified = true;
      }
      if (modified) {
        node.textContent = text;
      }
    }
  }
};

// Safety: Run only when the DOM is ready
if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", replaceDatePlaceholders);
} else {
  replaceDatePlaceholders();
}
</script>
