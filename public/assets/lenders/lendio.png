<!-- Sitewide EM to EF Swap Start -->
<script>
  document.addEventListener("DOMContentLoaded", function() {
    // --- CONFIGURATION START ---
    // List all the phrases you want to remove inside the brackets, in quotes.
    const termsToFind = ["Embedded Marketplace", "Embedded Lendingse"];
    
    // The single phrase you want to use instead.
    const termToReplace = "Embedded Financing";
    // --- CONFIGURATION END ---

    // Create a walker to find only text nodes (ignores HTML tags and attributes like href)
    const walker = document.createTreeWalker(
      document.body,
      NodeFilter.SHOW_TEXT,
      null,
      false
    );

    let node;
    // Loop through every text node on the page
    while (node = walker.nextNode()) {
      let currentText = node.nodeValue;
      let textChanged = false;

      // Check against every term in our list
      termsToFind.forEach(term => {
        if (currentText.includes(term)) {
          // Replace all instances of this specific term
          currentText = currentText.replace(new RegExp(term, 'g'), termToReplace);
          textChanged = true;
        }
      });

      // Update the browser text only if we found a match
      if (textChanged) {
        node.nodeValue = currentText;
      }
    }
  });
//window.$ = window.jQuery
</script></body></html>